---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title="Página no encontrada · jmaledom"
			description="Esta página no existe, pero puedes volver al inicio o seguir leyendo el blog de jmaledom."
		/>
	</head>
	<body>
		<Header />
		<main class="not-found">
			<section>
				<p class="code" aria-hidden="true">404</p>
				<p class="eyebrow">Página no encontrada</p>
				<h1>Aquí no sucede nada<span>.</span></h1>
				<p class="message">
					Puede que el enlace haya cambiado o que esta página nunca llegara a proceder.
					En cualquier caso, hay otros caminos por los que seguir.
				</p>
				<div class="actions">
					<a class="primary" href="/">Volver al inicio</a>
					<a class="secondary" href="/blog">Leer el blog</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.not-found {
		width: 1080px;
		min-height: 68vh;
		display: grid;
		place-items: center;
		padding-block: clamp(4rem, 10vw, 8rem);
		text-align: center;
	}
	.not-found section { max-width: 780px; }
	.code {
		margin: 0 0 -1.5rem;
		color: var(--surface);
		font-size: clamp(8rem, 24vw, 17rem);
		font-weight: 800;
		letter-spacing: -.09em;
		line-height: .7;
		-webkit-text-stroke: 1px var(--border);
		user-select: none;
	}
	.eyebrow {
		margin: 0 0 .75rem;
		color: var(--accent);
		font-size: .78rem;
		font-weight: 700;
		letter-spacing: .14em;
		text-transform: uppercase;
	}
	h1 {
		margin: 0;
		font-size: clamp(3.2rem, 8vw, 6.5rem);
		letter-spacing: -.065em;
		line-height: .92;
	}
	h1 span { color: var(--accent); }
	.message {
		max-width: 610px;
		margin: 1.5rem auto 0;
		color: var(--muted);
		font-size: 1.1rem;
	}
	.actions {
		display: flex;
		justify-content: center;
		gap: .85rem;
		margin-top: 2rem;
	}
	.actions a {
		padding: .72rem 1.2rem;
		border-radius: 999px;
		font-weight: 700;
		text-decoration: none;
	}
	.primary { color: white; background: var(--accent); }
	.secondary { color: var(--text); border: 1px solid var(--border); }
	.secondary:hover { color: var(--accent); border-color: var(--accent); }
	@media (max-width: 520px) {
		.not-found { padding-top: 3rem; }
		.code { margin-bottom: -.75rem; }
		.actions { flex-direction: column; align-items: stretch; }
	}
</style>

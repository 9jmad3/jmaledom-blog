---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title="Moderación de comentarios · jmaledom" description="Panel privado de comentarios." />
		<meta name="robots" content="noindex,nofollow" />
	</head>
	<body>
		<Header />
		<main class="moderation">
			<div class="moderation-heading">
				<div><p class="eyebrow">Administración</p><h1>Comentarios</h1></div>
				<div data-auth-actions>
					<button type="button" data-admin-login>Entrar con Google</button>
					<button type="button" data-admin-logout hidden>Cerrar sesión</button>
				</div>
			</div>
			<p data-admin-message>Inicia sesión con la cuenta configurada como administradora.</p>
			<section class="dashboard" data-dashboard hidden>
				<section class="analytics-panel" aria-labelledby="analytics-title">
					<div class="section-heading"><div><p class="eyebrow">Últimos 30 días</p><h2 id="analytics-title">Resumen del blog</h2></div><span class="analytics-note">Desde la activación de las métricas</span></div>
					<div class="cloudflare-history" data-cloudflare-history><p>Consultando el histórico de Cloudflare…</p></div>
					<div class="metric-grid" data-metric-grid aria-live="polite"><p>Cargando métricas…</p></div>
					<div class="chart-card"><h3>Visitas diarias</h3><div class="daily-chart" data-daily-chart></div></div>
					<div class="articles-card"><h3>Rendimiento por artículo</h3><div class="article-metrics" data-article-metrics></div></div>
				</section>
				<div class="status-tabs" role="tablist" aria-label="Estado de los comentarios">
					<button class="status-tab is-active" type="button" data-status="pending">Pendientes <span data-count="pending">0</span></button>
					<button class="status-tab" type="button" data-status="published">Publicados <span data-count="published">0</span></button>
					<button class="status-tab" type="button" data-status="rejected">Rechazados <span data-count="rejected">0</span></button>
				</div>
				<div class="filters">
					<label><span>Buscar</span><input type="search" data-search placeholder="Nombre o contenido…" autocomplete="off" /></label>
					<label><span>Artículo</span><select data-article-filter><option value="">Todos los artículos</option></select></label>
				</div>
				<p class="results-summary" data-results-summary></p>
				<div class="comment-list" data-comment-list></div>
			</section>
		</main>
	</body>
</html>

<script>
	import { authClient } from '../lib/auth-client';
	type Status = 'pending' | 'published' | 'rejected';
	type ModerationComment = { id: string; articleSlug: string; authorName: string; body: string; status: Status; moderationReason: string | null; createdAt: string };
	const message = document.querySelector<HTMLElement>('[data-admin-message]')!;
	const dashboard = document.querySelector<HTMLElement>('[data-dashboard]')!;
	const list = document.querySelector<HTMLElement>('[data-comment-list]')!;
	const login = document.querySelector<HTMLButtonElement>('[data-admin-login]')!;
	const logout = document.querySelector<HTMLButtonElement>('[data-admin-logout]')!;
	const search = document.querySelector<HTMLInputElement>('[data-search]')!;
	const articleFilter = document.querySelector<HTMLSelectElement>('[data-article-filter]')!;
	const summary = document.querySelector<HTMLElement>('[data-results-summary]')!;
	const metricGrid = document.querySelector<HTMLElement>('[data-metric-grid]')!;
	const dailyChart = document.querySelector<HTMLElement>('[data-daily-chart]')!;
	const articleMetrics = document.querySelector<HTMLElement>('[data-article-metrics]')!;
	const cloudflareHistory = document.querySelector<HTMLElement>('[data-cloudflare-history]')!;
	let comments: ModerationComment[] = [];
	let activeStatus: Status = 'pending';

	login.addEventListener('click', () => authClient.signIn.social({ provider: 'google', callbackURL: window.location.href }));
	logout.addEventListener('click', async () => { await authClient.signOut(); window.location.reload(); });

	async function moderate(id: string, action: 'publish' | 'reject', item: HTMLElement) {
		const buttons = item.querySelectorAll<HTMLButtonElement>('button');
		buttons.forEach((button) => button.disabled = true);
		const response = await fetch('/api/comments/moderation', { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id, action }) });
		if (response.ok) {
			const comment = comments.find((entry) => entry.id === id);
			if (comment) comment.status = action === 'publish' ? 'published' : 'rejected';
			message.textContent = '';
			render();
		} else {
			buttons.forEach((button) => button.disabled = false);
			message.textContent = 'No se ha podido actualizar el comentario.';
		}
	}

	async function removeComment(id: string, item: HTMLElement) {
		if (!window.confirm('¿Eliminar este comentario publicado? Esta acción no se puede deshacer.')) return;
		const buttons = item.querySelectorAll<HTMLButtonElement>('button');
		buttons.forEach((button) => button.disabled = true);
		const response = await fetch(`/api/comments/${id}`, { method: 'DELETE' });
		if (response.ok) {
			comments = comments.filter((comment) => comment.id !== id);
			message.textContent = '';
			render();
		} else {
			buttons.forEach((button) => button.disabled = false);
			message.textContent = 'No se ha podido eliminar el comentario.';
		}
	}

	function updateCounts() {
		for (const status of ['pending', 'published', 'rejected'] as Status[]) {
			document.querySelector<HTMLElement>(`[data-count="${status}"]`)!.textContent = String(comments.filter((comment) => comment.status === status).length);
		}
	}

	function createComment(comment: ModerationComment) {
		const item = document.createElement('article');
		item.className = 'moderation-comment';
		const title = document.createElement('strong');
		title.textContent = comment.authorName;
		const meta = document.createElement('div');
		meta.className = 'comment-meta';
		const article = document.createElement('a');
		article.href = `/blog/${comment.articleSlug}/`;
		article.textContent = comment.articleSlug;
		article.target = '_blank';
		article.rel = 'noopener';
		const date = document.createElement('time');
		date.dateTime = comment.createdAt;
		date.textContent = new Intl.DateTimeFormat('es-ES', { dateStyle: 'medium', timeStyle: 'short' }).format(new Date(comment.createdAt));
		meta.append(article, date);
		const body = document.createElement('p');
		body.textContent = comment.body;
		const actions = document.createElement('div');
		actions.className = 'comment-actions';
		if (comment.status === 'pending') {
			const publish = document.createElement('button');
			publish.className = 'primary-action';
			publish.textContent = 'Publicar';
			publish.addEventListener('click', () => moderate(comment.id, 'publish', item));
			const reject = document.createElement('button');
			reject.textContent = 'Rechazar';
			reject.addEventListener('click', () => moderate(comment.id, 'reject', item));
			actions.append(publish, reject);
		} else if (comment.status === 'published') {
			const remove = document.createElement('button');
			remove.className = 'danger-action';
			remove.textContent = 'Eliminar';
			remove.addEventListener('click', () => removeComment(comment.id, item));
			actions.append(remove);
		}
		item.append(title, meta, body);
		if (actions.children.length) item.append(actions);
		return item;
	}

	function render() {
		updateCounts();
		const query = search.value.trim().toLocaleLowerCase('es');
		const article = articleFilter.value;
		const filtered = comments.filter((comment) => comment.status === activeStatus && (!article || comment.articleSlug === article) && (!query || `${comment.authorName} ${comment.body}`.toLocaleLowerCase('es').includes(query)));
		list.replaceChildren();
		summary.textContent = `${filtered.length} ${filtered.length === 1 ? 'comentario' : 'comentarios'}`;
		if (!filtered.length) {
			const empty = document.createElement('p');
			empty.className = 'empty-state';
			empty.textContent = query || article ? 'No hay resultados con estos filtros.' : `No hay comentarios ${activeStatus === 'pending' ? 'pendientes' : activeStatus === 'published' ? 'publicados' : 'rechazados'}.`;
			list.append(empty);
			return;
		}
		for (const comment of filtered) list.append(createComment(comment));
	}

	document.querySelectorAll<HTMLButtonElement>('[data-status]').forEach((tab) => tab.addEventListener('click', () => {
		activeStatus = tab.dataset.status as Status;
		document.querySelectorAll('[data-status]').forEach((entry) => entry.classList.toggle('is-active', entry === tab));
		render();
	}));
	search.addEventListener('input', render);
	articleFilter.addEventListener('change', render);

	async function load() {
		const session = await authClient.getSession();
		if (!session.data) return;
		login.hidden = true;
		logout.hidden = false;
		const response = await fetch('/api/comments/moderation');
		if (response.status === 403) { message.textContent = 'Esta cuenta no tiene permiso para moderar.'; return; }
		if (!response.ok) { message.textContent = 'No se han podido cargar los comentarios.'; return; }
		const data = await response.json() as { comments: ModerationComment[] };
		comments = data.comments;
		for (const slug of [...new Set(comments.map((comment) => comment.articleSlug))].sort()) {
			const option = document.createElement('option');
			option.value = slug;
			option.textContent = slug;
			articleFilter.append(option);
		}
		message.textContent = '';
		dashboard.hidden = false;
		render();
		loadAnalytics();
	}

	function formatDuration(seconds: number) {
		if (!seconds) return '—';
		return `${Math.floor(seconds / 60)}:${String(seconds % 60).padStart(2, '0')} min`;
	}

	async function loadAnalytics() {
		const response = await fetch('/api/analytics/summary');
		if (!response.ok) { metricGrid.innerHTML = '<p>No se han podido cargar las métricas.</p>'; return; }
		const data = await response.json() as {
			summary: { totalViews: number; views30Days: number; readers30Days: number; viewsToday: number; averageSeconds: number; completionRate: number };
			daily: { date: string; views: number }[];
			articles: { articleSlug: string; views: number; readers: number; averageSeconds: number; completionRate: number; comments: number; reactions: number }[];
			cloudflare: { available: boolean; error?: string; from?: string; to?: string; pageViews?: number; visits?: number; topArticles?: { path: string; pageViews: number; visits: number }[] };
		};
		if (data.cloudflare.available) {
			const heading = document.createElement('div'); heading.className = 'history-heading';
			const title = document.createElement('strong'); title.textContent = 'Histórico de Cloudflare · últimos 6 meses';
			const totals = document.createElement('p'); totals.textContent = `${data.cloudflare.pageViews ?? 0} páginas vistas · ${data.cloudflare.visits ?? 0} visitas`;
			heading.append(title, totals);
			const paths = document.createElement('div'); paths.className = 'history-paths';
			for (const article of data.cloudflare.topArticles ?? []) {
				const row = document.createElement('p');
				const link = document.createElement('a'); link.href = article.path; link.textContent = article.path.split('/').filter(Boolean).at(-1) ?? article.path; link.target = '_blank';
				const value = document.createElement('span'); value.textContent = `${article.pageViews} vistas · ${article.visits} visitas`;
				row.append(link, value); paths.append(row);
			}
			cloudflareHistory.replaceChildren(heading, paths);
		} else {
			cloudflareHistory.classList.add('is-error');
			cloudflareHistory.textContent = data.cloudflare.error ?? 'Histórico de Cloudflare no disponible.';
		}
		const metrics = [
			['Visitas (30 días)', data.summary.views30Days],
			['Lectores aproximados', data.summary.readers30Days],
			['Visitas hoy', data.summary.viewsToday],
			['Tiempo medio activo', formatDuration(data.summary.averageSeconds)],
			['Lecturas completas', `${data.summary.completionRate}%`],
			['Visitas acumuladas', data.summary.totalViews],
		];
		metricGrid.replaceChildren(...metrics.map(([label, value]) => {
			const card = document.createElement('article');
			const strong = document.createElement('strong'); strong.textContent = String(value);
			const span = document.createElement('span'); span.textContent = String(label);
			card.append(strong, span); return card;
		}));
		const maxViews = Math.max(1, ...data.daily.map((day) => day.views));
		dailyChart.replaceChildren(...data.daily.map((day) => {
			const bar = document.createElement('span');
			bar.style.height = `${Math.max(3, (day.views / maxViews) * 100)}%`;
			bar.title = `${new Intl.DateTimeFormat('es-ES', { day: 'numeric', month: 'short' }).format(new Date(`${day.date}T12:00:00`))}: ${day.views} visitas`;
			bar.setAttribute('aria-label', bar.title);
			return bar;
		}));
		if (!data.articles.length) { articleMetrics.innerHTML = '<p>Aún no hay lecturas registradas.</p>'; return; }
		articleMetrics.replaceChildren(...data.articles.map((article) => {
			const row = document.createElement('article');
			const link = document.createElement('a'); link.href = `/blog/${article.articleSlug}/`; link.textContent = article.articleSlug; link.target = '_blank';
			const stats = document.createElement('p');
			stats.textContent = `${article.views} visitas · ${article.readers} lectores · ${formatDuration(article.averageSeconds)} · ${article.completionRate}% completas · ${article.comments} comentarios · ${article.reactions} reacciones`;
			row.append(link, stats); return row;
		}));
	}
	load();
</script>

<style>
	.moderation { width: min(920px, calc(100% - 2rem)); padding-top: 4rem; padding-bottom: 5rem; }
	.moderation-heading { display: flex; align-items: end; justify-content: space-between; gap: 1rem; }
	.moderation h1 { margin: 0; font-size: clamp(2.5rem, 7vw, 5rem); }
	.eyebrow { margin: 0 0 .4rem; color: var(--accent); font-size: .75rem; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; }
	[data-auth-actions] { display: flex; gap: .75rem; }
	button { padding: .7rem 1rem; color: var(--text); background: var(--surface); border: 1px solid var(--border); border-radius: 999px; cursor: pointer; }
	button:disabled { cursor: wait; opacity: .55; }
	.dashboard { margin-top: 2rem; }
	.analytics-panel { margin-bottom: 3rem; }
	.cloudflare-history { margin-bottom: .75rem; padding: 1rem; color: white; background: var(--text); border-radius: 16px; }
	.cloudflare-history.is-error { color: rgb(var(--gray)); background: var(--surface); border: 1px dashed var(--border); }
	.cloudflare-history :global(.history-heading) { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }
	.cloudflare-history :global(.history-heading p) { margin: 0; color: rgb(255 255 255 / .7); font-size: .85rem; }
	.cloudflare-history :global(.history-paths) { display: grid; gap: .5rem; margin-top: 1rem; }
	.cloudflare-history :global(.history-paths p) { display: flex; justify-content: space-between; gap: 1rem; margin: 0; padding-top: .5rem; border-top: 1px solid rgb(255 255 255 / .15); font-size: .78rem; }
	.cloudflare-history :global(.history-paths a) { color: white; font-weight: 700; text-decoration: none; }
	.cloudflare-history :global(.history-paths span) { color: rgb(255 255 255 / .7); }
	.section-heading { display: flex; align-items: end; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; }
	.section-heading h2 { margin: 0; font-size: clamp(1.7rem, 4vw, 2.5rem); }
	.analytics-note { color: rgb(var(--gray)); font-size: .75rem; }
	.metric-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: .75rem; }
	.metric-grid :global(article), .chart-card, .articles-card { padding: 1rem; background: var(--surface); border: 1px solid var(--border); border-radius: 16px; }
	.metric-grid :global(article) { display: flex; min-height: 92px; flex-direction: column; justify-content: space-between; }
	.metric-grid :global(strong) { font-size: 1.65rem; line-height: 1; }
	.metric-grid :global(span) { color: rgb(var(--gray)); font-size: .75rem; }
	.chart-card, .articles-card { margin-top: .75rem; }
	.chart-card h3, .articles-card h3 { margin: 0 0 1rem; font-size: 1rem; }
	.daily-chart { display: flex; height: 120px; align-items: end; gap: 4px; }
	.daily-chart :global(span) { min-width: 3px; flex: 1; background: var(--accent); border-radius: 3px 3px 0 0; opacity: .8; }
	.article-metrics { display: grid; gap: .8rem; }
	.article-metrics :global(article + article) { padding-top: .8rem; border-top: 1px solid var(--border); }
	.article-metrics :global(a) { color: var(--text); font-weight: 800; text-decoration: none; }
	.article-metrics :global(p) { margin: .3rem 0 0; color: rgb(var(--gray)); font-size: .78rem; line-height: 1.5; }
	.status-tabs { display: flex; gap: .65rem; overflow-x: auto; padding-bottom: .35rem; }
	.status-tab { flex: 0 0 auto; font-weight: 700; }
	.status-tab span { display: inline-grid; min-width: 1.55rem; min-height: 1.55rem; margin-left: .35rem; place-items: center; background: var(--background); border-radius: 999px; font-size: .72rem; }
	.status-tab.is-active { color: white; background: var(--text); border-color: var(--text); }
	.status-tab.is-active span { color: var(--text); background: var(--surface); }
	.filters { display: grid; grid-template-columns: 1fr minmax(210px, .55fr); gap: 1rem; margin-top: 1.5rem; }
	.filters label { display: grid; gap: .45rem; color: rgb(var(--gray)); font-size: .78rem; font-weight: 700; }
	.filters input, .filters select { width: 100%; padding: .8rem .9rem; color: var(--text); background: var(--surface); border: 1px solid var(--border); border-radius: 12px; font: inherit; }
	.results-summary { margin: 1.25rem 0 .75rem; color: rgb(var(--gray)); font-size: .85rem; }
	.comment-list { display: grid; gap: 1rem; }
	.comment-list :global(.moderation-comment) { padding: 1.25rem; background: var(--surface); border: 1px solid var(--border); border-radius: 16px; box-shadow: 0 12px 30px rgb(0 0 0 / .04); }
	.comment-list :global(.moderation-comment > strong) { display: block; margin-bottom: .2rem; font-size: 1.1rem; }
	.comment-list :global(.comment-meta) { display: flex; flex-wrap: wrap; gap: .35rem .75rem; color: rgb(var(--gray)); font-size: .8rem; }
	.comment-list :global(.comment-meta a) { color: var(--accent); font-weight: 700; text-decoration: none; }
	.comment-list :global(.moderation-comment > p) { margin: 1.15rem 0; line-height: 1.65; white-space: pre-wrap; overflow-wrap: anywhere; }
	.comment-list :global(.comment-actions) { display: flex; flex-wrap: wrap; gap: .6rem; }
	.comment-list :global(.comment-actions button) { padding: .6rem .9rem; font: inherit; font-size: .85rem; font-weight: 700; }
	.comment-list :global(.primary-action) { color: white; background: var(--accent); border-color: var(--accent); }
	.comment-list :global(.danger-action) { color: #a32a20; border-color: color-mix(in srgb, #a32a20 35%, var(--border)); }
	.comment-list :global(.empty-state) { padding: 2rem; color: rgb(var(--gray)); text-align: center; background: var(--surface); border: 1px dashed var(--border); border-radius: 16px; }
	[hidden] { display: none !important; }
	@media (max-width: 640px) { .moderation-heading, .section-heading, .cloudflare-history :global(.history-heading) { align-items: start; flex-direction: column; } .cloudflare-history :global(.history-paths p) { flex-direction: column; gap: .2rem; } .filters { grid-template-columns: 1fr; } .metric-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

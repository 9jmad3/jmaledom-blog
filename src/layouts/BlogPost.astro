---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ShareButton from '../components/ShareButton.astro';
import Comments from '../components/Comments.astro';

type PostLink = { id: string; title: string };
type Props = CollectionEntry<'blog'>['data'] & {
	readingMinutes: number;
	newerPost?: PostLink;
	olderPost?: PostLink;
};

const { title, description, pubDate, updatedDate, heroImage, socialImage, readingMinutes, newerPost, olderPost } = Astro.props;
const articleSlug = Astro.url.pathname.split('/').filter(Boolean).at(-1) ?? '';
---

<html lang="es">
	<head>
		<BaseHead title={title} description={description} image={socialImage ?? heroImage} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				width: min(100%, 720px);
				height: auto;
				object-position: center top;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.meta-separator { margin: 0 .45rem; }
			.post-navigation { margin: 4rem 0 2rem; padding-top: 2rem; border-top: 1px solid var(--border); }
			.post-navigation h2 { margin-bottom: 1.25rem; font-size: 1.5rem; }
			.post-links { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
			.post-link { display: flex; min-height: 110px; padding: 1rem; box-sizing: border-box; flex-direction: column; justify-content: space-between; color: var(--text); background: var(--surface); border: 1px solid var(--border); border-radius: 16px; text-decoration: none; transition: transform .2s ease, border-color .2s ease; }
			.post-link:hover { color: var(--text); border-color: var(--accent); transform: translateY(-3px); }
			.post-link small { color: var(--accent); font-size: .72rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }
			.post-link strong { line-height: 1.25; }
			@media (max-width: 600px) { .post-links { grid-template-columns: 1fr; } }
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} src={heroImage} alt={`Portada de «${title}»`} />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							<span class="meta-separator" aria-hidden="true">·</span>
							<span class="reading-time">{readingMinutes} min de lectura</span>
							{
								updatedDate && (
									<div class="last-updated-on">
										Actualizado el <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
					<ShareButton {title} {description} />
					<Comments article={articleSlug} />
					{(newerPost || olderPost) && (
						<nav class="post-navigation" aria-label="Más artículos">
							<h2>Sigue leyendo</h2>
							<div class="post-links">
								{olderPost && <a class="post-link" href={`/blog/${olderPost.id}/`}><small>Artículo anterior</small><strong>{olderPost.title}</strong></a>}
								{newerPost && <a class="post-link" href={`/blog/${newerPost.id}/`}><small>Artículo siguiente</small><strong>{newerPost.title}</strong></a>}
							</div>
						</nav>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
